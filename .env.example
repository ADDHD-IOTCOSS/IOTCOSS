APP_NAME=Mobius AI Gateway
ENVIRONMENT=development
API_PREFIX=/api/v1
DATABASE_PATH=./data/app.db
SESSION_TTL_SECONDS=86400
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Mobius oneM2M
MOBIUS_BASE_URL=https://platform.iotcoss.ac.kr/api/proxy/swagger/Mobius
MOBIUS_ORIGIN=S
MOBIUS_AE_NAME=ex
MOBIUS_AE_ID=
MOBIUS_DATA_CONTAINER=posture
MOBIUS_TIMEOUT_SECONDS=10
MOBIUS_AUTO_REGISTER=true
MOBIUS_API_KEY=
MOBIUS_LECTURE=
MOBIUS_CREATOR=

# AI: "local" works without an external service; "openai" uses the API below.
AI_PROVIDER=local
AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

