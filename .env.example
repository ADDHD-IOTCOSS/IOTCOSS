APP_NAME=Mobius AI Gateway
ENVIRONMENT=development
API_PREFIX=/api/v1
DATABASE_PATH=./data/app.db
SESSION_TTL_SECONDS=86400
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Mobius oneM2M
MOBIUS_BASE_URL=https://platform.iotcoss.ac.kr/api/proxy/swagger/Mobius
MOBIUS_ORIGIN=S
MOBIUS_AE_ID=
MOBIUS_TIMEOUT_SECONDS=10
MOBIUS_AUTO_REGISTER=true
MOBIUS_API_KEY=DdlBE1RhdrmEi4Apz6SP7XEtrVJr5HEE
MOBIUS_LECTURE=LCT_20260002
MOBIUS_CREATOR=sjuADDHD
# Mobius가 접근할 수 있는 이 서버의 공개 알림 주소
# 예: https://api.example.com/api/v1/mobius/notifications
MOBIUS_NOTIFICATION_URI=
MOBIUS_SUBSCRIPTION_NAME=subToAnalyticsServer
MOBIUS_SYNC_ON_STARTUP=true

# AI: "local" works without an external service; "openai" uses the API below.
AI_PROVIDER=local
AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

