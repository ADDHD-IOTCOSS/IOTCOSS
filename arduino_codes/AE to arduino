#include <WiFiS3.h>
#include <ArduinoJson.h>

const char* ssid = "와이파이이름";
const char* password = "비밀번호";

const char* host = "platform.iotcoss.ac.kr";

const char* apiKey = "DdlBE1RhdrmEi4Apz6SP7XEtrVJr5HEE";
const char* lecture = "LCT_20260002";
const char* creator = "sjuADDHD";

const int LED_PIN = 13;

WiFiSSLClient client;

void setup() {

  Serial.begin(115200);

  pinMode(LED_PIN, OUTPUT);

  while (WiFi.begin(ssid, password) != WL_CONNECTED) {
    delay(1000);
    Serial.println("Connecting...");
  }

  Serial.println("WiFi Connected");
}

void loop() {

  if (client.connect(host, 443)) {

    client.println("GET /api/proxy/swagger/Mobius/ex/posture/la HTTP/1.1");
    client.println("Host: platform.iotcoss.ac.kr");

    client.print("X-M2M-RI: ");
    client.println("123");

    client.print("X-M2M-Origin: ");
    client.println("S");

    client.print("X-API-KEY: ");
    client.println(apiKey);

    client.print("X-AUTH-CUSTOM-LECTURE: ");
    client.println(lecture);

    client.print("X-AUTH-CUSTOM-CREATOR: ");
    client.println(creator);

    client.println("Accept: application/json");
    client.println("Connection: close");
    client.println();

    while (client.connected()) {

      String line = client.readStringUntil('\n');

      if (line == "\r")
        break;
    }

    String body = "";

    while (client.available()) {

      body += (char)client.read();
    }

    Serial.println(body);

    JsonDocument doc;

    DeserializationError error = deserializeJson(doc, body);

    if (!error) {

      bool neck =
          doc["m2m:cin"]["con"]["neck_forward"];

      float angle =
          doc["m2m:cin"]["con"]["mCRA"];

      Serial.print("Angle : ");
      Serial.println(angle);

      Serial.print("Neck : ");
      Serial.println(neck);

      if (neck)
        digitalWrite(LED_PIN, HIGH);
      else
        digitalWrite(LED_PIN, LOW);
    }

    client.stop();
  }

  delay(1000);
}
